{
  "Application": {
    "Name": "Spendly.Api",
    "DisplayName": "Spendly API",
    "Version": "v1"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "HealthChecks": {
    "Enabled": true,
    "LivePath": "/health/live",
    "ReadyPath": "/health/ready"
  },
  "OpenApi": {
    "Enabled": false,
    "DocumentName": "v1",
    "Endpoint": "/openapi/{documentName}.json"
  },
  "Infrastructure": {
    "Database": {
      "Provider": "NotConfigured"
    }
  },
  "AllowedHosts": "*"
}
