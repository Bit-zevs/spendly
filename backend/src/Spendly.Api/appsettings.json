{
  "Application": {
    "Name": "Spendly.Api",
    "DisplayName": "Spendly API",
    "Version": "v0.2"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.Environment"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "Properties": {
      "Application": "Spendly.Api"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "HealthChecks": {
    "Enabled": true,
    "LivePath": "/health/live",
    "ReadyPath": "/health/ready"
  },
  "OpenApi": {
    "Enabled": false,
    "DocumentName": "v0.2",
    "Endpoint": "/openapi/{documentName}.json",
    "ScalarEndpoint": "/docs"
  },
  "Infrastructure": {
    "Database": {
      "Provider": "NotConfigured"
    }
  },
  "AllowedHosts": "*"
}
